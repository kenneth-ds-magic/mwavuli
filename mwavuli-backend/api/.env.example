# Copy to .env and fill in.
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Postgres — the API connects as the NOSUPERUSER, NOBYPASSRLS app role.
DATABASE_URL=postgres://mwavuli_app:change-me-in-prod@localhost:5432/mwavuli

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TTL=900          # seconds (15 min)
JWT_REFRESH_TTL=2592000     # seconds (30 days)

# CORS (comma-separated origins; * for dev only)
CORS_ORIGIN=*

# Rate limiting
RATE_LIMIT_MAX=120          # requests
RATE_LIMIT_WINDOW=60000     # ms

# Object storage (S3-compatible). Originals are private; derivatives public.
S3_REGION=us-east-1
S3_BUCKET_UPLOADS=mwavuli-uploads-private
S3_BUCKET_PUBLIC=mwavuli-public
S3_PUBLIC_BASE_URL=http://localhost:9000/mwavuli-public
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
VERIFY_VOTES_REQUIRED=2

# Identification provider (open-source). Leave blank to use the stub.
PLANTNET_API_KEY=
PLANTNET_ENDPOINT=https://my-api.plantnet.org/v2/identify/all
